<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Add Password Entry"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp" />

        <EditText
            android:id="@+id/titleInput"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="Title (required)"
            android:padding="12dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/edit_text_background" />

        <EditText
            android:id="@+id/usernameInput"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="Username (required)"
            android:padding="12dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/edit_text_background" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <EditText
                android:id="@+id/passwordInput"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:inputType="textPassword"
                android:hint="Password (required)"
                android:padding="12dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/edit_text_background" />

            <Button
                android:id="@+id/generatePasswordButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:text="Gen" />

        </LinearLayout>

        <EditText
            android:id="@+id/urlInput"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:inputType="uri"
            android:hint="URL (optional)"
            android:padding="12dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/edit_text_background" />

        <EditText
            android:id="@+id/totpInput"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="TOTP Secret (optional)"
            android:padding="12dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/edit_text_background" />

        <EditText
            android:id="@+id/notesInput"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:hint="Notes (optional)"
            android:padding="12dp"
            android:layout_marginBottom="24dp"
            android:gravity="top"
            android:background="@drawable/edit_text_background" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/saveButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="Save"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/cancelButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="Cancel"
                android:layout_marginStart="8dp" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>
